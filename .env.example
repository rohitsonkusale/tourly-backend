# ================================================
# Tourly Backend — Environment Variables
# Copy this to .env and fill in real values.
# For production, set these as system env vars or in your deployment config.
# ================================================

# ── Spring Profile ──
SPRING_PROFILES_ACTIVE=prod

# ── Database ──
DB_URL=jdbc:mysql://your-production-host:3306/tourly_db
DB_USERNAME=tourly_prod_user
DB_PASSWORD=your_secure_db_password

# ── JWT ──
# Generate with: openssl rand -base64 64
JWT_SECRET=your_256bit_random_secret_here
JWT_EXPIRATION=3600000

# ── Razorpay ──
RAZORPAY_KEY=rzp_live_xxxxxxxxx
RAZORPAY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ── Google OAuth ──
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://api.roamaya.in/api/auth/google/callback

# ── Cloudinary ──
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_UPLOAD_PRESET=your_upload_preset

# ── CORS ──
CORS_ALLOWED_ORIGINS=https://roamaya.in,https://www.roamaya.in

# ── Logging (production) ──
LOG_LEVEL_APP=INFO
LOG_LEVEL_SECURITY=WARN
LOG_LEVEL_SQL=WARN
LOG_LEVEL_SQL_BINDER=WARN
JPA_SHOW_SQL=false

# ── Flyway ──
FLYWAY_CLEAN_DISABLED=true

# ── Server ──
SERVER_PORT=8080
